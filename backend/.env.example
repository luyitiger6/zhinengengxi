# 应用配置
DEBUG=true

# LLM配置 (MiniMax via oneapi)
# oneapi 地址，例如 http://localhost:3000/v1
LLM_BASE_URL=http://localhost:3000/v1
# oneapi 中配置的模型名称，如 MiniMax-M2.7-highspeed
LLM_MODEL=MiniMax-M2.7-highspeed
# oneapi 的 API Key（从 oneapi 渠道设置页面获取）
LLM_API_KEY=your_api_key_here

# 数据库配置 (SQLite)
DB_TYPE=sqlite
DB_PATH=data/zhinengengxi.db

# Qdrant配置（可选，向量搜索功能）
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=query_history
